#!/usr/bin/env bash
# Autopilot dispatcher — cron entry point for the autonomous PR pipeline.
# Designed for 15-second cron ticks: exits in <10ms on no-op (PAUSE, locked).
# Full state machine drives tasks from pending → completed.

set -euo pipefail

# Source shared entry-point helpers.
# shellcheck source=lib/entry-common.sh
source "${BASH_SOURCE[0]%/*}/../lib/entry-common.sh"

# Print usage information.
_usage() {
  cat <<USAGE
Usage: autopilot-dispatch PROJECT_DIR

Autopilot dispatcher — runs one state-machine tick for the PR pipeline.

Arguments:
  PROJECT_DIR   Path to the project directory (default: current directory)

Options:
  -h, --help    Show this help message

Examples:
  autopilot-dispatch /path/to/project
  autopilot-dispatch .
USAGE
}

readonly _EXTRA_POSITIONAL_HINT="autopilot-dispatch takes only one argument (the project directory)"
parse_base_args "$@"

PROJECT_DIR="$(resolve_project_dir "$PROJECT_DIR_ARG")"
readonly PROJECT_DIR
LIB_DIR="$(resolve_lib_dir "${BASH_SOURCE[0]}")"
readonly LIB_DIR

# Quick guards — exit immediately if paused or locked.
check_quick_guards "$PROJECT_DIR" "pipeline" || exit 0

# Bootstrap: source dispatcher, load config, init state, acquire lock.
bootstrap_and_lock "$PROJECT_DIR" "pipeline" "dispatcher.sh" "$LIB_DIR" || exit 0

# Run the state machine.
dispatch_tick "$PROJECT_DIR"
