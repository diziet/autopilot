#!/usr/bin/env bash
# Autopilot dispatcher — cron entry point for the autonomous PR pipeline.
# Designed for 15-second cron ticks: exits in <10ms on no-op (PAUSE, locked).
# Full state machine drives tasks from pending → completed.

set -euo pipefail

# Resolve the project directory from the first argument or pwd.
PROJECT_DIR="${1:-.}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"
readonly PROJECT_DIR

# Resolve the autopilot install directory (where lib/ lives).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib"

# Source shared entry-point helpers.
# shellcheck source=lib/entry-common.sh
source "${LIB_DIR}/entry-common.sh"

# Quick guards — exit immediately if paused or locked.
check_quick_guards "$PROJECT_DIR" "pipeline" || exit 0

# Bootstrap: source dispatcher, load config, init state, acquire lock.
bootstrap_and_lock "$PROJECT_DIR" "pipeline" "dispatcher.sh" "$LIB_DIR" || exit 0

# Run the state machine.
dispatch_tick "$PROJECT_DIR"
