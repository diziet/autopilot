#!/usr/bin/env bash
# Autopilot init — interactive setup command that scaffolds a project
# for the autopilot PR pipeline. Idempotent: re-running skips existing files.

set -euo pipefail

# Resolve the lib directory relative to this script, following symlinks.
_resolve_lib_dir() {
  local source="${BASH_SOURCE[0]}"
  while [[ -L "$source" ]]; do
    local dir
    dir="$(cd "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  local script_dir
  script_dir="$(cd "$(dirname "$source")" && pwd)"
  echo "${script_dir}/../lib"
}

_INIT_LIB_DIR="$(_resolve_lib_dir)"
readonly _INIT_LIB_DIR

# Print usage information.
_usage() {
  cat <<USAGE
Usage: autopilot-init [OPTIONS]

Initialize a project for the autopilot PR pipeline.

Scaffolds config, tasks, .gitignore, and scheduling in a paused state.
Re-running is safe — existing files are not overwritten.

Options:
  -h, --help    Show this help message

Examples:
  cd my-project && autopilot-init
  autopilot-init
USAGE
}

# Parse arguments.
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) _usage; exit 0 ;;
    -*) echo "Error: unknown option: $1" >&2; _usage >&2; exit 1 ;;
    *) echo "Error: unexpected argument: $1" >&2; _usage >&2; exit 1 ;;
  esac
done

# Track what was created/modified for the summary.
_CREATED_FILES=()
_MODIFIED_FILES=()
_SKIPPED_FILES=()

# Record a created file.
_track_created() { _CREATED_FILES+=("$1"); }

# Record a modified file.
_track_modified() { _MODIFIED_FILES+=("$1"); }

# Record a skipped file.
_track_skipped() { _SKIPPED_FILES+=("$1"); }

# Print an info message.
_info() { echo "  [OK] $1"; }

# Print a skip message.
_skip() { echo "  [SKIP] $1"; }

# Print a warning message.
_warn() { echo "  [WARN] $1"; }

# Print an error message.
_err() { echo "  [ERROR] $1" >&2; }

# --- Step 1: Verify prerequisites ---

# Required tools and their install hints.
_get_install_hint() {
  case "$1" in
    claude)  echo "See https://docs.anthropic.com/en/docs/claude-code" ;;
    gh)      echo "brew install gh" ;;
    jq)      echo "brew install jq" ;;
    git)     echo "Install via Xcode Command Line Tools: xcode-select --install" ;;
    timeout) echo "brew install coreutils (macOS does not include GNU timeout)" ;;
    *) echo "Install $1 and ensure it is on PATH" ;;
  esac
}

# Check all required tools are available.
verify_prerequisites() {
  echo "Checking prerequisites..."
  local missing=0
  local tool
  for tool in claude gh jq git timeout; do
    if command -v "$tool" >/dev/null 2>&1; then
      _info "$tool found"
    else
      _err "$tool not found — $(_get_install_hint "$tool")"
      missing=1
    fi
  done
  if [[ "$missing" -eq 1 ]]; then
    echo ""
    echo "Install missing tools and re-run autopilot-init."
    exit 1
  fi
  echo ""
}

# --- Step 2: Verify git repo ---

# Ensure we're in a git repo with a GitHub remote.
verify_git_repo() {
  echo "Checking git repository..."
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "  Not a git repository."
    _prompt_or_fail "  Initialize git repo here?" "git init"
    git init -q
    _info "Initialized git repository"
  else
    _info "Git repository found"
  fi

  if ! git remote get-url origin >/dev/null 2>&1; then
    echo "  No GitHub remote (origin) found."
    _prompt_or_fail "  Create a GitHub repo with 'gh repo create'?" "gh repo create"
    gh repo create --source=. --push
    _info "Created GitHub repository"
  else
    _info "GitHub remote found: $(git remote get-url origin)"
  fi
  echo ""
}

# Prompt user for yes/no, abort if not interactive or user says no.
_prompt_or_fail() {
  local message="$1"
  local command_hint="$2"
  if [[ ! -t 0 ]]; then
    _err "Non-interactive mode. Run: ${command_hint}"
    exit 1
  fi
  read -r -p "${message} [y/N] " answer
  if [[ "$answer" != [yY] && "$answer" != [yY][eE][sS] ]]; then
    echo "  Aborted. Run: ${command_hint}"
    exit 1
  fi
}

# --- Step 3: Verify gh auth ---

# Ensure gh CLI is authenticated.
verify_gh_auth() {
  echo "Checking GitHub authentication..."
  if gh auth status >/dev/null 2>&1; then
    _info "gh is authenticated"
  else
    _err "gh is not authenticated. Run: gh auth login"
    exit 1
  fi
  echo ""
}

# --- Step 4: Scaffold tasks.md ---

# Generate sample tasks.md if it doesn't exist.
scaffold_tasks() {
  echo "Checking tasks file..."
  if [[ -f "tasks.md" ]]; then
    _skip "tasks.md already exists"
    _track_skipped "tasks.md"
  else
    _write_sample_tasks
    _info "Generated tasks.md with sample tasks — edit with your own tasks or try it as-is."
    _track_created "tasks.md"
  fi
  echo ""
}

# Write the sample tasks.md content.
_write_sample_tasks() {
  cat > "tasks.md" << 'TASKS'
# Project Tasks

## Previously Completed Tasks

<!-- Autopilot moves completed task summaries here automatically. -->

---

## Task 1: Add README.md

Create a README.md describing this project. Include: what it does, how to install, how to run, and how to test. Infer the project purpose from existing files.

## Task 2: Add .gitignore

Create a .gitignore appropriate for this project. Detect the language/framework from existing files and include the standard ignore patterns (build artifacts, dependency dirs, IDE files, OS files).
TASKS
}

# --- Step 5: Scaffold autopilot.conf ---

# Generate autopilot.conf if it doesn't exist.
scaffold_config() {
  echo "Checking config file..."
  if [[ -f "autopilot.conf" ]]; then
    _skip "autopilot.conf already exists"
    _track_skipped "autopilot.conf"
    echo ""
    return
  fi

  local test_cmd=""
  if [[ -t 0 ]]; then
    read -r -p "  Do you have a test command? (e.g., 'make test', 'npm test') [enter to skip] " test_cmd
  fi

  _write_config "$test_cmd"
  _info "Generated autopilot.conf"
  _track_created "autopilot.conf"
  echo ""
}

# Write the autopilot.conf with --dangerously-skip-permissions enabled.
_write_config() {
  local test_cmd="$1"
  cat > "autopilot.conf" << 'CONF'
# autopilot.conf — Project configuration for Autopilot
# Only lines matching AUTOPILOT_[A-Z_]+= are parsed.

# Required for unattended mode (cron/launchd).
AUTOPILOT_CLAUDE_FLAGS="--dangerously-skip-permissions"

CONF

  if [[ -n "$test_cmd" ]]; then
    # Escape double quotes in the user-provided value.
    local escaped_cmd="${test_cmd//\"/\\\"}"
    echo "# Custom test command." >> "autopilot.conf"
    echo "AUTOPILOT_TEST_CMD=\"${escaped_cmd}\"" >> "autopilot.conf"
  fi
}

# --- Step 5b: Scaffold CLAUDE.md ---

# Count total lines in a file.
_count_lines() {
  local file="$1"
  wc -l < "$file" | tr -d ' '
}

# Skip CLAUDE.md scaffolding if file has enough lines. Returns 0 if skipped.
_skip_claude_md_if_adequate() {
  local file="$1"
  local message="$2"
  local -r min_lines=10
  local line_count
  line_count="$(_count_lines "$file")"
  if [[ "$line_count" -gt "$min_lines" ]]; then
    _skip "$message"
    _track_skipped "CLAUDE.md"
    echo ""
    return 0
  fi
  return 1
}

# Generate CLAUDE.md from the example template if no adequate one exists.
scaffold_claude_md() {
  echo "Checking CLAUDE.md..."
  local is_replacing=false
  if [[ -f "CLAUDE.md" ]]; then
    if _skip_claude_md_if_adequate "CLAUDE.md" "Existing CLAUDE.md found — skipping."; then
      return
    fi
    is_replacing=true
  fi

  local global_claude="${HOME}/.claude/CLAUDE.md"
  if [[ -f "$global_claude" ]]; then
    if _skip_claude_md_if_adequate "$global_claude" "Global CLAUDE.md found with engineering standards — skipping project CLAUDE.md."; then
      return
    fi
  fi

  local example_src="${_INIT_LIB_DIR}/../examples/CLAUDE.example.md"
  if [[ -f "$example_src" ]]; then
    cp "$example_src" "CLAUDE.md"
    if [[ "$is_replacing" == true ]]; then
      _info "Replaced short CLAUDE.md with default agent instructions — edit the Project Details section for your stack."
    else
      _info "Generated CLAUDE.md with default agent instructions — edit the Project Details section for your stack."
    fi
    _track_created "CLAUDE.md"
  else
    _warn "CLAUDE.example.md not found — skipping CLAUDE.md generation"
  fi
  echo ""
}

# --- Step 5c: Check worktree-escaping symlinks ---

# Source preflight for the symlink scanner.
# shellcheck source=lib/preflight.sh
source "${_INIT_LIB_DIR}/preflight.sh"

# If escaping symlinks found, auto-disable worktrees in autopilot.conf.
check_symlinks_for_worktrees() {
  echo "Checking for worktree-incompatible symlinks..."
  if check_worktree_compatibility "." >/dev/null 2>&1; then
    _info "No symlinks escaping repo root"
  else
    _warn "Tracked symlinks that escape the repo root detected."
    echo "  Worktrees would break these symlinks because the worktree"
    echo "  lives at a different directory depth than the project root."
    if [[ ! -f "autopilot.conf" ]]; then
      _warn "autopilot.conf not found — add AUTOPILOT_USE_WORKTREES=false manually"
    elif grep -q 'AUTOPILOT_USE_WORKTREES' "autopilot.conf"; then
      _skip "AUTOPILOT_USE_WORKTREES already set in autopilot.conf"
    else
      echo "" >> "autopilot.conf"
      echo "# Auto-disabled: tracked symlinks escape the repo root." >> "autopilot.conf"
      echo 'AUTOPILOT_USE_WORKTREES="false"' >> "autopilot.conf"
      _info "Set AUTOPILOT_USE_WORKTREES=false in autopilot.conf"
      _track_modified "autopilot.conf"
    fi
  fi
  echo ""
}

# --- Step 6: Update .gitignore ---

# Append .autopilot/ to .gitignore if not already present.
update_gitignore() {
  echo "Checking .gitignore..."
  if [[ -f ".gitignore" ]]; then
    if grep -qF '.autopilot/' ".gitignore"; then
      _skip ".autopilot/ already in .gitignore"
      _track_skipped ".gitignore"
    else
      echo '.autopilot/' >> ".gitignore"
      _info "Appended .autopilot/ to .gitignore"
      _track_modified ".gitignore"
    fi
  else
    echo '.autopilot/' > ".gitignore"
    _info "Created .gitignore with .autopilot/"
    _track_created ".gitignore"
  fi
  echo ""
}

# --- Step 7: Account detection ---

# Check for multi-account Claude setup.
detect_accounts() {
  echo "Checking Claude account setup..."
  local has_acct1=false
  local has_acct2=false
  [[ -d "${HOME}/.claude-account1" ]] && has_acct1=true
  [[ -d "${HOME}/.claude-account2" ]] && has_acct2=true

  if [[ "$has_acct1" == true && "$has_acct2" == true ]]; then
    _info "Two-account setup detected (~/.claude-account1 and ~/.claude-account2)"
    echo "  Tip: Use --dispatcher-account 1 --reviewer-account 2 with autopilot-schedule"
    echo "  to separate billing and avoid rate-limit contention."
  elif [[ "$has_acct1" == true || "$has_acct2" == true ]]; then
    _info "Single account directory found — single-account setup"
  else
    _info "No account directories found — single-account setup is fine"
  fi
  echo ""
}

# --- Step 8: Set up scheduling ---

# Install launchd agents (macOS) or print cron instructions (Linux).
setup_scheduling() {
  echo "Setting up scheduling..."
  local project_dir
  project_dir="$(pwd)"

  if [[ "$(uname -s)" == "Darwin" ]]; then
    local schedule_cmd=""
    # Prefer PATH lookup (allows override in tests), fall back to sibling binary.
    if command -v autopilot-schedule >/dev/null 2>&1; then
      schedule_cmd="autopilot-schedule"
    elif [[ -x "${_INIT_LIB_DIR}/../bin/autopilot-schedule" ]]; then
      schedule_cmd="${_INIT_LIB_DIR}/../bin/autopilot-schedule"
    fi
    if [[ -n "$schedule_cmd" ]]; then
      if "$schedule_cmd" "$project_dir"; then
        _info "Launchd agents installed"
      else
        _warn "autopilot-schedule failed — run it manually after fixing the issue"
      fi
    else
      _warn "autopilot-schedule not found — run 'autopilot-schedule $(pwd)' after install"
    fi
  else
    echo "  On Linux, add cron entries manually:"
    echo "    */1 * * * * cd ${project_dir} && autopilot-dispatch ."
    echo "    */1 * * * * cd ${project_dir} && autopilot-review ."
    _info "Printed cron instructions"
  fi
  echo ""
}

# --- Step 9: Touch PAUSE file ---

# Create .autopilot/PAUSE so the pipeline is installed but paused.
create_pause_file() {
  echo "Creating pause file..."
  if [[ -f ".autopilot/PAUSE" ]]; then
    _skip ".autopilot/PAUSE already exists"
    _track_skipped ".autopilot/PAUSE"
  else
    mkdir -p ".autopilot"
    touch ".autopilot/PAUSE"
    _info "Created .autopilot/PAUSE — pipeline is paused"
    _track_created ".autopilot/PAUSE"
  fi
  echo ""
}

# --- Step 10: Print summary ---

# Print what was created/modified.
print_summary() {
  echo "════════════════════════════════════════════════════════════"
  echo "  Setup complete!"
  echo "════════════════════════════════════════════════════════════"
  echo ""

  if [[ ${#_CREATED_FILES[@]} -gt 0 ]]; then
    echo "  Created:"
    local f
    for f in "${_CREATED_FILES[@]}"; do
      echo "    + $f"
    done
  fi

  if [[ ${#_MODIFIED_FILES[@]} -gt 0 ]]; then
    echo "  Modified:"
    local f
    for f in "${_MODIFIED_FILES[@]}"; do
      echo "    ~ $f"
    done
  fi

  if [[ ${#_SKIPPED_FILES[@]} -gt 0 ]]; then
    echo "  Skipped (already exist):"
    local f
    for f in "${_SKIPPED_FILES[@]}"; do
      echo "    - $f"
    done
  fi

  echo ""
  echo "  Edit tasks.md if needed, then run: autopilot start"
  echo ""
}

# --- Main ---

echo ""
echo "Autopilot Init"
echo "──────────────────────────────────────────────────────────────"
echo ""

verify_prerequisites
verify_git_repo
verify_gh_auth
scaffold_tasks
scaffold_config
scaffold_claude_md
check_symlinks_for_worktrees
update_gitignore
detect_accounts
setup_scheduling
create_pause_file
print_summary
