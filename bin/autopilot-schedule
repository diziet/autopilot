#!/usr/bin/env bash
# Generate and install macOS launchd plists for an autopilot project.
# Usage: autopilot-schedule [OPTIONS] PROJECT_DIR
#
# Supports per-role accounts via --dispatcher-account and --reviewer-account
# (or --account for both). See --help for details.

set -euo pipefail

readonly DEFAULT_INTERVAL=15
readonly LAUNCH_AGENTS_DIR="$HOME/Library/LaunchAgents"

# Print usage information.
usage() {
  cat <<USAGE
Usage: autopilot-schedule [OPTIONS] PROJECT_DIR

Generate and install macOS launchd plists for autopilot.

Options:
  --interval SECS           StartInterval for launchd (default: ${DEFAULT_INTERVAL})
  --account NUM             Account identifier for both roles (default: 1)
  --dispatcher-account NUM  Account for dispatcher (overrides --account)
  --reviewer-account NUM    Account for reviewer (overrides --account)
  --uninstall               Unload and remove installed plists
  --generate-only           Generate plists to stdout without installing
  -h, --help                Show this help message

When ~/.claude-account{NUM} exists on disk, CLAUDE_CONFIG_DIR is set
in that role's plist environment to point to it.

Examples:
  autopilot-schedule /path/to/project
  autopilot-schedule --interval 30 --account 2 /path/to/project
  autopilot-schedule --dispatcher-account 1 --reviewer-account 2 /path/to/project
  autopilot-schedule --uninstall /path/to/project
USAGE
}

# Resolve the autopilot bin directory, following symlinks.
_resolve_bin_dir() {
  local source="${BASH_SOURCE[0]}"
  while [[ -L "$source" ]]; do
    local dir
    dir="$(cd "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd "$(dirname "$source")" && pwd
}

# Resolve the plists template directory.
_resolve_plists_dir() {
  local bin_dir="$1"
  echo "${bin_dir}/../plists"
}

# Build the plist label from role and account.
_build_label() {
  local role="$1" account="$2"
  echo "com.autopilot.${role}.${account}"
}

# Resolve CLAUDE_CONFIG_DIR path for a given account number.
_resolve_config_dir() {
  local account="$1"
  local config_dir="${HOME}/.claude-account${account}"
  if [[ -d "$config_dir" ]]; then
    echo "$config_dir"
  fi
}

# Resolve the directory containing the claude binary.
_resolve_claude_bin_dir() {
  local claude_cmd="${AUTOPILOT_CLAUDE_CMD:-claude}"

  if [[ "$claude_cmd" == /* ]]; then
    # Absolute path — extract directory directly
    dirname "$claude_cmd"
    return
  fi

  # Bare command name — resolve via command -v
  local resolved
  resolved="$(command -v "$claude_cmd" 2>/dev/null)" || true
  if [[ -n "$resolved" ]]; then
    dirname "$resolved"
  fi
}

# Build extra PATH entries for the claude binary directory.
_build_claude_path_entries() {
  local bin_dir="$1"
  # ~/.local/bin is in the plist template statically; include it here to avoid duplicates
  local static_dirs="${HOME}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/sbin"

  # Resolve claude binary directory
  local claude_dir
  claude_dir="$(_resolve_claude_bin_dir)"

  if [[ -n "$claude_dir" ]] && \
     [[ "$claude_dir" != "$bin_dir" ]] && \
     [[ ":${static_dirs}:" != *":${claude_dir}:"* ]]; then
    echo "${claude_dir}:"
  fi
}

# Substitute template markers with actual values.
_substitute_plist() {
  local template_file="$1"
  local project_dir="$2"
  local account="$3"
  local interval="$4"
  local bin_dir="$5"
  local role="$6"
  local command="$7"
  local config_dir="${8:-}"
  local log_dir="${project_dir}/.autopilot/logs"

  # Resolve extra PATH entries for the claude binary
  local claude_bin_dir
  claude_bin_dir="$(_build_claude_path_entries "$bin_dir")"

  # Build common sed expressions.
  local sed_args=(
    -e "s|__AUTOPILOT_PROJECT_DIR__|${project_dir}|g"
    -e "s|__AUTOPILOT_ACCOUNT__|${account}|g"
    -e "s|__AUTOPILOT_START_INTERVAL__|${interval}|g"
    -e "s|__AUTOPILOT_BIN_DIR__|${bin_dir}|g"
    -e "s|__CLAUDE_BIN_DIR__|${claude_bin_dir}|g"
    -e "s|__HOME__|${HOME}|g"
    -e "s|__AUTOPILOT_HOME__|${HOME}|g"
    -e "s|__AUTOPILOT_LOG_DIR__|${log_dir}|g"
    -e "s|__AUTOPILOT_ROLE__|${role}|g"
    -e "s|__AUTOPILOT_COMMAND__|${command}|g"
  )

  # Add or remove extra env lines based on config_dir.
  if [[ -n "$config_dir" ]]; then
    sed_args+=(
      -e "s|__AUTOPILOT_EXTRA_ENV_KEY__|    <key>CLAUDE_CONFIG_DIR</key>|"
      -e "s|__AUTOPILOT_EXTRA_ENV_VAL__|    <string>${config_dir}</string>|"
    )
  else
    sed_args+=(
      -e "/__AUTOPILOT_EXTRA_ENV_KEY__/d"
      -e "/__AUTOPILOT_EXTRA_ENV_VAL__/d"
    )
  fi

  sed "${sed_args[@]}" "$template_file"
}

# Install a single plist: copy to LaunchAgents and load.
_install_plist() {
  local label="$1"
  local plist_content="$2"
  local dest="${LAUNCH_AGENTS_DIR}/${label}.plist"

  mkdir -p "$LAUNCH_AGENTS_DIR"

  # Unload existing agent if present (ignore errors)
  launchctl bootout "gui/$(id -u)/${label}" 2>/dev/null || true

  echo "$plist_content" > "$dest"
  launchctl bootstrap "gui/$(id -u)" "$dest"
  echo "  Installed and loaded: ${label}"
}

# Uninstall a single plist: unload and remove.
_uninstall_plist() {
  local label="$1"
  local dest="${LAUNCH_AGENTS_DIR}/${label}.plist"

  if [[ -f "$dest" ]]; then
    launchctl bootout "gui/$(id -u)/${label}" 2>/dev/null || true
    rm -f "$dest"
    echo "  Unloaded and removed: ${label}"
  else
    echo "  Not found: ${dest}"
  fi
}

# Map role name to command name.
_role_to_command() {
  case "$1" in
    dispatcher) echo "autopilot-dispatch" ;;
    reviewer)   echo "autopilot-review" ;;
    *) echo "autopilot-$1" ;;
  esac
}

# Generate plist content for a given role.
generate_plist() {
  local role="$1"
  local project_dir="$2"
  local account="$3"
  local interval="$4"
  local config_dir="${5:-}"

  local bin_dir
  bin_dir="$(_resolve_bin_dir)"

  local plists_dir
  plists_dir="$(_resolve_plists_dir "$bin_dir")"

  local template="${plists_dir}/com.autopilot.agent.plist"
  if [[ ! -f "$template" ]]; then
    echo "Error: template not found: ${template}" >&2
    return 1
  fi

  local command
  command="$(_role_to_command "$role")"

  _substitute_plist "$template" "$project_dir" "$account" "$interval" "$bin_dir" "$role" "$command" "$config_dir"
}

# Install plists for both dispatcher and reviewer.
install_plists() {
  local project_dir="$1"
  local dispatcher_account="$2"
  local reviewer_account="$3"
  local interval="$4"

  # Ensure log directory exists
  mkdir -p "${project_dir}/.autopilot/logs"

  echo "Installing autopilot launchd agents..."
  echo "  Project: ${project_dir}"
  echo "  Dispatcher account: ${dispatcher_account}"
  echo "  Reviewer account: ${reviewer_account}"
  echo "  Interval: ${interval}s"
  echo ""

  local role account label content config_dir
  for role in dispatcher reviewer; do
    if [[ "$role" == "dispatcher" ]]; then
      account="$dispatcher_account"
    else
      account="$reviewer_account"
    fi
    config_dir="$(_resolve_config_dir "$account")"
    label="$(_build_label "$role" "$account")"
    content="$(generate_plist "$role" "$project_dir" "$account" "$interval" "$config_dir")"
    _install_plist "$label" "$content"
  done

  echo ""
  echo "Launchd agents installed. View status with:"
  echo "  launchctl list | grep autopilot"
  echo ""
  echo "View logs at:"
  echo "  ${project_dir}/.autopilot/logs/dispatcher.stdout.log"
  echo "  ${project_dir}/.autopilot/logs/reviewer.stdout.log"
}

# Uninstall plists for both dispatcher and reviewer.
uninstall_plists() {
  local project_dir="$1"
  local dispatcher_account="$2"
  local reviewer_account="$3"

  echo "Removing autopilot launchd agents..."
  echo ""

  local label
  label="$(_build_label "dispatcher" "$dispatcher_account")"
  _uninstall_plist "$label"
  label="$(_build_label "reviewer" "$reviewer_account")"
  _uninstall_plist "$label"

  echo ""
  echo "Launchd agents removed."
}

# Validate account format: alphanumeric with optional hyphens or underscores.
_validate_account() {
  local label="$1" value="$2"
  if ! [[ "$value" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo "Error: ${label} must be alphanumeric (with optional - or _), got: ${value}" >&2
    exit 1
  fi
}

# Parse command-line arguments and dispatch.
main() {
  local interval="$DEFAULT_INTERVAL"
  local account="1"
  local dispatcher_account=""
  local reviewer_account=""
  local do_uninstall=false
  local generate_only=false
  local project_dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --interval)
        [[ $# -lt 2 ]] && { echo "Error: --interval requires a value" >&2; exit 1; }
        interval="$2"
        shift 2
        ;;
      --account)
        [[ $# -lt 2 ]] && { echo "Error: --account requires a value" >&2; exit 1; }
        account="$2"
        shift 2
        ;;
      --dispatcher-account)
        [[ $# -lt 2 ]] && { echo "Error: --dispatcher-account requires a value" >&2; exit 1; }
        dispatcher_account="$2"
        shift 2
        ;;
      --reviewer-account)
        [[ $# -lt 2 ]] && { echo "Error: --reviewer-account requires a value" >&2; exit 1; }
        reviewer_account="$2"
        shift 2
        ;;
      --uninstall)
        do_uninstall=true
        shift
        ;;
      --generate-only)
        generate_only=true
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      -*)
        echo "Error: unknown option: $1" >&2
        usage >&2
        exit 1
        ;;
      *)
        project_dir="$1"
        shift
        ;;
    esac
  done

  # Default per-role accounts to the shared --account value.
  [[ -z "$dispatcher_account" ]] && dispatcher_account="$account"
  [[ -z "$reviewer_account" ]] && reviewer_account="$account"

  # Validate project directory.
  if [[ -z "$project_dir" ]]; then
    echo "Error: PROJECT_DIR is required" >&2
    usage >&2
    exit 1
  fi
  if [[ ! -d "$project_dir" ]]; then
    echo "Error: directory not found: ${project_dir}" >&2
    exit 1
  fi
  project_dir="$(cd "$project_dir" && pwd)"

  # Validate interval is a positive integer.
  if ! [[ "$interval" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: --interval must be a positive integer, got: ${interval}" >&2
    exit 1
  fi

  # Validate all account values.
  _validate_account "--account" "$account"
  _validate_account "--dispatcher-account" "$dispatcher_account"
  _validate_account "--reviewer-account" "$reviewer_account"

  # Reject conflicting flags.
  if [[ "$do_uninstall" == true && "$generate_only" == true ]]; then
    echo "Error: --uninstall and --generate-only are mutually exclusive" >&2
    exit 1
  fi

  if [[ "$do_uninstall" == true ]]; then
    uninstall_plists "$project_dir" "$dispatcher_account" "$reviewer_account"
  elif [[ "$generate_only" == true ]]; then
    local d_cfg r_cfg
    d_cfg="$(_resolve_config_dir "$dispatcher_account")"
    r_cfg="$(_resolve_config_dir "$reviewer_account")"
    generate_plist "dispatcher" "$project_dir" "$dispatcher_account" "$interval" "$d_cfg"
    echo "---"
    generate_plist "reviewer" "$project_dir" "$reviewer_account" "$interval" "$r_cfg"
  else
    install_plists "$project_dir" "$dispatcher_account" "$reviewer_account" "$interval"
  fi
}

main "$@"
