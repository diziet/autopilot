#!/usr/bin/env bash
# Autopilot start — validate setup and start the pipeline.
# Always runs autopilot-doctor first. If all checks pass and the pipeline
# is paused, removes the PAUSE file. Exits 0 on success or if already running.

set -euo pipefail

# Resolve symlinks so sourcing works when invoked via a symlink.
# SYNC: Keep in sync with resolve_script_path() in lib/entry-common.sh.
_self="${BASH_SOURCE[0]}"
while [[ -L "$_self" ]]; do
  _dir="$(cd "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
# shellcheck source=lib/entry-common.sh
source "$(cd "$(dirname "$_self")/.." && pwd)/lib/entry-common.sh"
unset _self _dir

LIB_DIR="$(resolve_lib_dir "${BASH_SOURCE[0]}")"
readonly LIB_DIR

# Print usage information.
_usage() {
  cat <<USAGE
Usage: autopilot-start [OPTIONS] [PROJECT_DIR]

Validate project setup and start the autopilot pipeline.

Runs autopilot-doctor to check setup. If all checks pass, removes
the .autopilot/PAUSE file so the pipeline begins processing tasks.

Arguments:
  PROJECT_DIR   Path to the project directory (default: current directory)

Options:
  -h, --help    Show this help message

Examples:
  autopilot-start
  autopilot-start /path/to/project
USAGE
}

# Use shared argument parsing from entry-common.sh.
parse_base_args "$@"

PROJECT_DIR="$(resolve_project_dir "$PROJECT_DIR_ARG")"
readonly PROJECT_DIR

# Locate autopilot-doctor via shared helper.
DOCTOR_CMD="$(find_sibling_binary "autopilot-doctor" "$LIB_DIR")"
if [[ -z "$DOCTOR_CMD" ]]; then
  echo "Error: autopilot-doctor not found on PATH or in bin/" >&2
  exit 1
fi

# Locate autopilot-schedule via shared helper.
SCHEDULE_CMD="$(find_sibling_binary "autopilot-schedule" "$LIB_DIR")"

# Offer to run autopilot-schedule when scheduler check fails.
_offer_scheduler_install() {
  if [[ -z "$SCHEDULE_CMD" ]]; then
    echo "autopilot-schedule not found — install it first, then run: autopilot-schedule ${PROJECT_DIR}"
    return 1
  fi

  if [[ -t 0 ]]; then
    echo "Would you like to install the scheduler now? [y/N]"
    local reply
    read -r reply
    if [[ "$reply" =~ ^[Yy] ]]; then
      if "$SCHEDULE_CMD" "$PROJECT_DIR"; then
        echo ""
        echo "Scheduler installed. Re-run autopilot-start to continue."
      else
        echo "Scheduler installation failed."
      fi
      return
    fi
  fi

  echo "Run: autopilot-schedule ${PROJECT_DIR}"
}

# Always run doctor to validate setup, regardless of PAUSE state.
# Stream output in real-time via tee, capturing to a temp file for post-analysis.
# Export AUTOPILOT_COLOR so doctor emits ANSI codes through the pipe when appropriate.
DOCTOR_TMPFILE="$(mktemp)"
trap 'rm -f "$DOCTOR_TMPFILE"' EXIT
if [[ -t 1 ]]; then
  export AUTOPILOT_COLOR=1
fi
DOCTOR_STATUS=0
"$DOCTOR_CMD" "$PROJECT_DIR" 2>&1 | tee "$DOCTOR_TMPFILE" || DOCTOR_STATUS=${PIPESTATUS[0]}

if [[ "$DOCTOR_STATUS" -ne 0 ]]; then
  echo ""
  # If scheduler check failed, offer to install it.
  # Strip ANSI codes before grepping — temp file may contain escape sequences.
  if sed 's/\x1b\[[0-9;]*m//g' "$DOCTOR_TMPFILE" | grep -qF '[FAIL] No scheduler found'; then
    _offer_scheduler_install
  fi
  echo "Start aborted — fix the issues above and try again."
  exit 1
fi

# All checks passed — check PAUSE state and act accordingly.
if [[ ! -f "${PROJECT_DIR}/.autopilot/PAUSE" ]]; then
  echo ""
  echo "Pipeline is already running."
  exit 0
fi

# Remove the PAUSE file and ensure logs directory exists.
rm -f "${PROJECT_DIR}/.autopilot/PAUSE"
mkdir -p "${PROJECT_DIR}/.autopilot/logs"

echo ""
echo "Pipeline started. Watch progress: tail -f .autopilot/logs/pipeline.log"
