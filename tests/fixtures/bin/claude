#!/usr/bin/env bash
# Mock claude CLI for testing. Simulates a coder agent that creates
# files and commits. Outputs JSON matching --output-format json shape.
#
# Env vars:
#   CLAUDE_MOCK_DIR     — directory containing behavior config
#   CLAUDE_MOCK_EXIT    — exit immediately with this code (skips actions and output)
#   CLAUDE_MOCK_NO_PUSH — if set, default action commits but does not push
#                         (ignored when actions.sh is provided)
set -euo pipefail

readonly MOCK_DIR="${CLAUDE_MOCK_DIR:-/tmp/claude-mock}"

# Ensure mock dir exists for logging.
mkdir -p "$MOCK_DIR"

# Log every call with full args.
echo "claude $*" >> "$MOCK_DIR/claude-calls.log"

# Exit code override.
if [[ -n "${CLAUDE_MOCK_EXIT:-}" ]]; then
  exit "$CLAUDE_MOCK_EXIT"
fi

# Source custom actions if provided, otherwise run default behavior.
_run_actions() {
  if [[ -f "$MOCK_DIR/actions.sh" ]]; then
    # shellcheck source=/dev/null
    source "$MOCK_DIR/actions.sh"
  else
    _default_action
  fi
}

# Default: create a single file and commit it.
_default_action() {
  local work_dir
  work_dir="$(pwd)"

  echo "mock change" > "$work_dir/mock-output.txt"

  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git add -A >/dev/null 2>&1
    git commit -m "feat: mock claude commit" >/dev/null 2>&1

    if [[ -z "${CLAUDE_MOCK_NO_PUSH:-}" ]]; then
      # Only push if a remote exists.
      if git remote get-url origin >/dev/null 2>&1; then
        git push >/dev/null 2>&1 || true
      fi
    fi
  fi
}

# Run the actions.
_run_actions

# Output JSON matching Claude's --output-format json shape.
cat <<'EOF'
{"result": "Task complete.", "session_id": "mock-session-123"}
EOF
